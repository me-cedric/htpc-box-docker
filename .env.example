# Your timezone, https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Europe/Paris
# UNIX PUID and PGID, find with: id $USER
PUID=1000
PGID=1000
# Local network mask, find with: ip route | awk '!/ (docker0|br-)/ && /src/ {print $1}'
NETWORK=192.168.1.0/24
# Servername for outside redirection with traefik
SERVERNAME=test.com
# The directory where data will be stored.
ROOT=/path/to/network/share
# The directory where configuration will be stored.
CONFIG=/config
DOMAIN=your.domain.com
EMAIL=xxxxxxxxxx@xxxxxxxx.xxx
# Plex
PLEX_CLAIM=claim-xxxxxxxxxxxxxxxxxxx
# NordVPN informations, generate with: curl https://api.nordvpn.com/v1/users/services/credentials -u 'token:your_token_goes_here'
VPN_KEY=nordvpn-dashboard-service-credentials
VPN_COUNTRY=France
# MariaDB
MYSQL_PASSWORD=SqLpAsSwOrD
MYSQL_DATABASE=nextcloud
MYSQL_USER=username
# Nextcloud
NEXTCLOUD_ADMIN_USER=username
NEXTCLOUD_ADMIN_PASSWORD=NeXtClOuDpAsSwOrD
# Duplicati
DUPLICATI__WEBSERVICE_PASSWORD=DuPlIcAtIpAsSwOrD
# Homarr && PocketId
# can be generate using `openssl rand -hex 32`
ENCRYPTIONKEY=SuperSecretEncriptionKey
HOMARR_OIDC_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HOMARR_OIDC_CLIENT_SECRET=SuperSecretHomarrClientSecret
# Radarr / Sonarr API Keys (used by Swaparr)
RADARR_API_KEY=your_radarr_api_key
SONARR_API_KEY=your_sonarr_api_key
# Decluttarr configuration
# General
DECLUTTARR_LOG_LEVEL=INFO
DECLUTTARR_TEST_RUN=false
DECLUTTARR_TIMER=120
DECLUTTARR_SSL_VERIFICATION=true
DECLUTTARR_PRIVATE_TRACKER_HANDLING=remove
DECLUTTARR_PUBLIC_TRACKER_HANDLING=remove
DECLUTTARR_OBSOLETE_TAG=Obsolete
DECLUTTARR_PROTECTED_TAG=Keep

# Jobs (true/false)
DECLUTTARR_REMOVE_BAD_FILES=true
DECLUTTARR_REMOVE_FAILED_DOWNLOADS=true
DECLUTTARR_REMOVE_FAILED_IMPORTS=true
DECLUTTARR_REMOVE_METADATA_MISSING=true
DECLUTTARR_REMOVE_MISSING_FILES=true
DECLUTTARR_REMOVE_ORPHANS=true
DECLUTTARR_REMOVE_SLOW=true
DECLUTTARR_REMOVE_STALLED=true
DECLUTTARR_REMOVE_UNMONITORED=true
DECLUTTARR_SEARCH_UNMET_CUTOFF=true
DECLUTTARR_SEARCH_MISSING=true
DECLUTTARR_DETECT_DELETIONS=true

# Optional: advanced behavior
DECLUTTARR_DELETE_OLDER_THAN=7d
DECLUTTARR_DRY_RUN=false

# Decluttarr instance endpoints (use container static IPs for continuity)
DECLUTTARR_SONARR_BASE_URL=http://192.168.89.105:8989
DECLUTTARR_RADARR_BASE_URL=http://192.168.89.104:7878
DECLUTTARR_QBITTORRENT_BASE_URL=http://192.168.89.160:8123
# Optional: qBittorrent credentials (provide only if your qBittorrent WebUI/API requires authentication)
# Leave blank to use anonymous access when allowed by your setup
DECLUTTARR_QBITTORRENT_USERNAME=
DECLUTTARR_QBITTORRENT_PASSWORD=
# Pi-Hole
WEBPASSWORD="correct horse battery staple"
# Random 32+ char string for session cookie encryption
OIDC_SECRET="<generate with: openssl rand -hex 16>"
# From PocketID: create an OIDC client, copy these values
OIDC_CLIENT_ID=<client-id-from-pocketid>
OIDC_CLIENT_SECRET=<client-secret-from-pocketid>
# Home assistant
HOST_IP=192.168.1.53